#Now we begin the loop over all entries in our directory. Currently we're locked into only using the 0 directory.

echo "starting up!"


wget -nv -m -np -nH --cut-dirs=5 -R "index.html*" --execute robots=off --wait=1 https://heasarc.gsfc.nasa.gov/FTP/xrism/data/obs/2/$1/


#Unzip everything
echo "Unzipping!"
gunzip $1/resolve/event_cl/*.gz
echo "Unzipping!"
gunzip $1/auxil/*.gz
echo "Unzipping!"
gunzip $1/resolve/event_uf/*.gz
echo "Unzipping!"
gunzip $1/resolve/products/*.gz

#Now let's use xselect to grab the .pi file
printf "read events\nno\nread events $1/resolve/event_cl/xa%srsl_p0px1000_cl.evt\n.\nfilter GRADE "0:0"\nextr spectrum\nsave spectrum\n outputFile.pi\nexit\nno\n" "$1" | xselect

mv outputFile.pi $1

echo "Moving to RMF!"

#And now the rmf file!
punlearn rslmkrmf

echo "RUNNING RSLMKRMF"

rslmkrmf mode=h \
chatter=3 \
infile=$1/resolve/event_cl/xa${1}rsl_p0px1000_cl.evt \
outfileroot=$1/outputFile \
regmode=DET \
whichrmf=L \
resolist=0 \
regionfile=ALLPIX



echo "Moving to ARF!"

#And finally the .arf file. This one takes a little bit more doing
punlearn xaexpmap
xaexpmap ehkfile=$1/auxil/xa${1}.ehk gtifile=$1/resolve/event_cl/xa${1}rsl_p0px1000_cl.evt instrume=RESOLVE badimgfile=NONE pixgtifile=$1/resolve/event_uf/xa${1}rsl_px1000_exp.gti outfile=$1/resolve/event_cl/N132D_rsl.expo outmaptype=EXPOSURE delta=20.0 numphi=1


rightAscension=$(fkeyprint $1/resolve/event_cl/xa${1}rsl_p0px1000_cl.evt[EVENTS] RA_OBJ | awk '/^RA_OBJ/ {print $3}')
echo "$rightAscension"

declension=$(fkeyprint $1/resolve/event_cl/xa${1}rsl_p0px1000_cl.evt[EVENTS] DEC_OBJ | awk '/^DEC_OBJ/ {print $3}')
echo "$declension"

punlearn xaarfgen
xaarfgen xrtevtfile=$1/resolve/event_cl/raytrace_N132D_rsl_pt.fits source_ra=${rightAscension} source_dec=${declension} telescop=XRISM instrume=RESOLVE emapfile=$1/resolve/event_cl/N132D_rsl.expo regmode=DET regionfile=$1/resolve/products/xa${1}rsl_det_fullarray.reg sourcetype=POINT rmffile=$1/outputFile.rmf erange="1.5 18.0 0 0" outfile=$1/outputFile.arf numphoton=300000 qefile=CALDB contamifile=CALDB gatevalvefile=CALDB onaxisffile=CALDB onaxiscfile=CALDB mirrorfile=CALDB obstructfile=CALDB frontreffile=CALDB backreffile=CALDB pcolreffile=CALDB scatterfile=CALDB imgfile=NONE~


rm -r $1/auxil
rm -r $1/log
rm -r $1/resolve
rm -r $1/xtend

echo "done!"