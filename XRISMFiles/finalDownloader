#Now we begin the loop over all entries in our directory. Currently we're locked into only using a single directory, but since there are only ten directories in total, we should be fine to just repeat this program ten times, if desired.

echo "starting up!"

touch datasetList

echo "\n" > datasetList

counter=0

for fileNo in $(curl -s "$1" | grep -oE '[0-9]{6,}')

do

#First we see if the dataset is any good
curl -fsI "${1}${fileNo}/resolve/event_cl/" >/dev/null || continue

#For some reason, it reads every dataset twice. This is a pretty dumb way to get around the problem, but it does work
if [ $((counter % 2)) -ne 0 ]; then
((counter++))
echo "Skipping"
continue # Skip this iteration

fi
((counter++))

#Announce it works
echo "${fileNo} is compatible!"

#Now we actually get to work on it
wget -nv -m -np -nH --cut-dirs=5 -R "index.html*" --execute robots=off --wait=1 https://heasarc.gsfc.nasa.gov/FTP/xrism/data/obs/0/$fileNo/

#Record the file for later
echo $fileNo >> datasetList

#Unzip everything
echo "Unzipping!"
gunzip $fileNo/resolve/event_cl/*.gz
echo "Unzipping!"
gunzip $fileNo/auxil/*.gz
echo "Unzipping!"
gunzip $fileNo/resolve/event_uf/*.gz
echo "Unzipping!"
gunzip $fileNo/resolve/products/*.gz

#Now let's use xselect to grab the .pi file
printf "read events\nno\nread events $fileNo/resolve/event_cl/xa%srsl_p0px1000_cl.evt\n.\nfilter GRADE "0:0"\nextr spectrum\nsave spectrum\n outputFile.pi\nexit\nno\n" "$fileNo" | xselect

mv outputFile.pi $fileNo

#And now the rmf file!
echo "Moving to the rmf file!"

punlearn rslmkrmf
echo "xa${fileNo}rsl_p0px1000_cl.evt"
echo $fileNo/resolve/event_cl/*


rslmkrmf infile=$fileNo/resolve/event_cl/xa${fileNo}rsl_p0px1000_cl.evt outfileroot=$fileNo/outputFile regmode=DET whichrmf=L resolist=0 regionfile=ALLPIX

echo "Moving to the arf file!"

#And finally the .arf file. This one takes a little bit more doing
punlearn xaexpmap
xaexpmap ehkfile=$fileNo/auxil/xa${fileNo}.ehk gtifile=$fileNo/resolve/event_cl/xa${fileNo}rsl_p0px1000_cl.evt instrume=RESOLVE badimgfile=NONE pixgtifile=$fileNo/resolve/event_uf/xa${fileNo}rsl_px1000_exp.gti outfile=$fileNo/resolve/event_cl/N132D_rsl.expo outmaptype=EXPOSURE delta=20.0 numphi=1


rightAscension=$(fkeyprint $fileNo/resolve/event_cl/xa${fileNo}rsl_p0px1000_cl.evt[EVENTS] RA_OBJ | awk '/^RA_OBJ/ {print $3}')
echo "$rightAscension"

declension=$(fkeyprint $fileNo/resolve/event_cl/xa${fileNo}rsl_p0px1000_cl.evt[EVENTS] DEC_OBJ | awk '/^DEC_OBJ/ {print $3}')
echo "$declension"

punlearn xaarfgen
xaarfgen xrtevtfile=$fileNo/resolve/event_cl/raytrace_N132D_rsl_pt.fits source_ra=${rightAscension} source_dec=${declension} telescop=XRISM instrume=RESOLVE emapfile=$fileName/resolve/event_cl/N132D_rsl.expo regmode=DET regionfile=$fileNo/resolve/products/xa${fileNo}rsl_det_fullarray.reg sourcetype=POINT rmffile=$fileNo/outputFile.rmf erange="1.5 18.0 0 0" outfile=$fileNo/outputFile.arf numphoton=300000 qefile=CALDB contamifile=CALDB gatevalvefile=CALDB onaxisffile=CALDB onaxiscfile=CALDB mirrorfile=CALDB obstructfile=CALDB frontreffile=CALDB backreffile=CALDB pcolreffile=CALDB scatterfile=CALDB imgfile=NONE~


echo "Deleting excess files to free up storage!"

#rm -r $fileNo/auxi
#rm -r $fileNo/log
#rm -r $fileNo/resolve
#rm -r $fileNo/xtend

echo "Finished with ${fileNo}!"

done

echo "done!"